{
  "name": "smartdinebackend",
  "version": "1.0.0",
  "description": "A secure and scalable Node.js backend application",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "security:audit": "npm audit",
    "prepare": "husky install",
    "deploy": "pm2 start src/server.js --name smartdinebackend --watch"
  },
  "keywords": [
    "node",
    "express",
    "api",
    "redis",
    "jwt",
    "security"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@firebase/auth": "^1.10.5",
    "@google-cloud/logging-winston": "^6.0.1",
    "@google-cloud/secret-manager": "^6.0.1",
    "bcrypt": "^5.1.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^6.7.0",
    "firebase-admin": "^13.4.0",
    "helmet": "^6.1.5",
    "image-to-pdf": "^3.0.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "nodemailer": "^7.0.3",
    "payu-websdk": "^1.3.1",
    "pm2": "^6.0.8",
    "uuid": "^11.1.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.19",
    "eslint": "^8.39.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^27.2.1",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "jest": "^29.5.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^13.2.2",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
